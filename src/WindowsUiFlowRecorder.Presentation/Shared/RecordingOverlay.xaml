<Window x:Class="WindowsUiFlowRecorder.Presentation.Shared.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Width="200" Height="40"
        AllowsTransparency="True" Background="Transparent">
    <Border CornerRadius="6" Padding="8" Background="#66000000">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Ellipse x:Name="RecordingDot" Width="10" Height="10" Fill="Red" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusLabel" Text="Recording" Foreground="White" FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>