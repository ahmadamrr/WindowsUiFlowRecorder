<Window x:Class="WindowsUiFlowRecorder.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows UI Flow Recorder &amp; Smart UI Scanner"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="10" CornerRadius="4">
            <TextBlock Text="Windows UI Flow Recorder &amp; Smart UI Scanner"
                       FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <TabControl Grid.Row="1" Margin="0,10,0,10">
            <TabItem Header="Recorder">
                <Grid Margin="5">
                    <TextBlock Text="Flow Recorder - Phase 2 Build"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
            <TabItem Header="Smart UI Scanner">
                <Grid Margin="5">
                    <TextBlock Text="Smart UI Scanner - Phase 2 Build"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
            <TabItem Header="Profiles">
                <Grid Margin="5">
                    <TextBlock Text="Application Profiles - Phase 2 Build"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <Grid Margin="5">
                    <TextBlock Text="Settings - Phase 2 Build"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#007ACC" Padding="8" CornerRadius="4">
            <TextBlock x:Name="StatusText" Text="Status: Idle" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>