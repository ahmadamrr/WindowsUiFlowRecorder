<Window x:Class="WindowsUiFlowRecorder.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:recorder="clr-namespace:WindowsUiFlowRecorder.Presentation.Recorder"
        xmlns:scanner="clr-namespace:WindowsUiFlowRecorder.Presentation.Scanner"
        Title="Windows UI Flow Recorder &amp; Smart UI Scanner"
        Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#2D2D30" BorderThickness="0">
            <TabItem Header="Flow Recorder" Background="#3E3E42" Foreground="#CCC">
                <recorder:RecorderView/>
            </TabItem>
            <TabItem Header="Smart UI Scanner" Background="#3E3E42" Foreground="#CCC">
                <scanner:ScannerView/>
            </TabItem>
            <TabItem Header="Application Profiles" Background="#3E3E42" Foreground="#CCC">
                <Grid Margin="10">
                    <TextBlock Text="Profile management will be built in Phase 9"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
            <TabItem Header="Settings" Background="#3E3E42" Foreground="#CCC">
                <Grid Margin="10">
                    <TextBlock Text="Settings UI will be built in Phase 9"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="14" Foreground="#666"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>